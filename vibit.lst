   660                              <1> ;==============================================================================
   661                              <1> ; parse_line(buf, argv, max_args) — Split line into argv array
   662                              <1> ;
   663                              <1> ; Input:  rdi = null-terminated input line
   664                              <1> ;         rsi = argv buffer (array of pointers)
   665                              <1> ;         ecx = max args
   666                              <1> ; Output: rax = argc
   667                              <1> ;
   668                              <1> ; Splits on whitespace (space, tab).  Handles single and double quotes.
   669                              <1> ; Destroys buf content (inserts null terminators).
   670                              <1> ;==============================================================================
   671                              <1> parse_line:
   672 00000DF9 53                  <1>     push rbx
   673 00000DFA 4154                <1>     push r12
   674 00000DFC 4155                <1>     push r13
   675 00000DFE 4156                <1>     push r14
   676 00000E00 4157                <1>     push r15
   677                              <1> 
   678 00000E02 4989FC              <1>     mov r12, rdi                    ; r12 = input pointer
   679 00000E05 4989F5              <1>     mov r13, rsi                    ; r13 = argv buffer
   680 00000E08 4189CE              <1>     mov r14d, ecx                   ; r14 = max args
   681 00000E0B 4531FF              <1>     xor r15d, r15d                  ; r15 = argc
   682                              <1> 
   683                              <1> .pl_skip_ws:
   684                              <1>     ; Skip leading whitespace
   685 00000E0E 418A0424            <1>     mov al, [r12]
   686 00000E12 84C0                <1>     test al, al
   687 00000E14 0F8493000000        <1>     jz .pl_done
   688 00000E1A 3C20                <1>     cmp al, ' '
   689 00000E1C 7406                <1>     je .pl_skip_char
   690 00000E1E 3C09                <1>     cmp al, 0x09                    ; tab
   691 00000E20 7402                <1>     je .pl_skip_char
   692 00000E22 EB05                <1>     jmp .pl_token_start
   693                              <1> 
   694                              <1> .pl_skip_char:
   695 00000E24 49FFC4              <1>     inc r12
   696 00000E27 EBE5                <1>     jmp .pl_skip_ws
   697                              <1> 
   698                              <1> .pl_token_start:
   699                              <1>     ; Check for max args
   700 00000E29 4539F7              <1>     cmp r15d, r14d
   701 00000E2C 737F                <1>     jae .pl_done
   702                              <1> 
   703                              <1>     ; Store pointer in argv
   704 00000E2E 4F8964FD00          <1>     mov [r13 + r15*8], r12
   705 00000E33 41FFC7              <1>     inc r15d
   706                              <1> 
   707                              <1>     ; Parse token: handle quoted vs unquoted
   708 00000E36 41803C2422          <1>     cmp byte [r12], '"'
