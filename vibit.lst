   161 000009C2 00                  <1>
   162 000009C3 488D35B1050000      <1>     lea rsi, [rel str_reboot_msg]
   163 000009CA BF01000000          <1>     mov rdi, 1
   164 000009CF E878FAFFFF          <1>     call write_str
   165 000009D4 E8AAFAFFFF          <1>     call write_newline
   166 000009D9 E989000000          <1>     jmp .exit_shell
   167                              <1> 
   168                              <1> .check_empty:
