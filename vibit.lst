   462                              <1> ; ── History display helper ───────────────────────────────────────────────────
   463                              <1> ; Called from readline after up/down arrow.  Clears current line and
   464                              <1> ; displays history entry at index r15.
   465                              <1> ; Input: r15 = history browse index
   466                              <1> ;        r12 = current buffer, r14 = current position (destroyed then reset)
   467                              <1> ;        r13 = max length
   468                              <1> history_display:
   469 00000C65 50                  <1>     push rax
   470 00000C66 51                  <1>     push rcx
   471 00000C67 57                  <1>     push rdi
   472 00000C68 56                  <1>     push rsi
   473 00000C69 52                  <1>     push rdx
   474                              <1> 
   475                              <1>     ; Clear current line from cursor position back to prompt
   476                              <1>     ; Move back to prompt position
   477 00000C6A 4489F1              <1>     mov ecx, r14d                   ; number of chars to erase
   478 00000C6D 85C9                <1>     test ecx, ecx
   479 00000C6F 742D                <1>     jz .hd_show
   480                              <1> 
   481                              <1> .hd_erase_loop:
   482                              <1>     ; Backspace: 0x08, space, 0x08
   483 00000C71 C64424F008          <1>     mov byte [rsp - 16], 0x08
   484 00000C76 BF01000000          <1>     mov rdi, 1
   485 00000C7B 488D7424F0          <1>     lea rsi, [rsp - 16]
   486 00000C80 BA01000000          <1>     mov rdx, 1
   487 00000C85 B801000000          <1>     mov rax, 1
   488 00000C8A 0F05                <1>     syscall
   489                              <1> 
   490 00000C8C C64424F020          <1>     mov byte [rsp - 16], 0x20
   491 00000C91 0F05                <1>     syscall
   492                              <1> 
   493 00000C93 C64424F008          <1>     mov byte [rsp - 16], 0x08
   494 00000C98 0F05                <1>     syscall
   495                              <1> 
   496 00000C9A FFC9                <1>     dec ecx
   497 00000C9C 75D3                <1>     jnz .hd_erase_loop
   498                              <1> 
   499                              <1> .hd_show:
   500                              <1>     ; Get history entry at index r15
   501 00000C9E 488D3DF3060000      <1>     lea rdi, [rel history_buf]
