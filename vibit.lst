   488                                  %include "vibix_shell.inc"
     1                              <1> ;==============================================================================
     2                              <1> ; vibix_shell.inc — Interactive serial shell for VIBIX
     3                              <1> ;
     4                              <1> ; Provides: shell() — main entry point (read-eval-print loop)
     5                              <1> ;
     6                              <1> ; Depends on: vibix_core.inc (write_str, strlen, write_newline)
     7                              <1> ;
     8                              <1> ; Features:
     9                              <1> ;   - Readline with backspace editing
    10                              <1> ;   - Command history (4 entries, up/down arrow navigation)
    11                              <1> ;   - Command table dispatch (echo, cat, printenv, clear, true, false)
    12                              <1> ;   - Builtins: exit, help, history, clear, poweroff, reboot
    13                              <1> ;   - Error messages for unknown commands
    14                              <1> ;
    15                              <1> ; Include AFTER all other inc files so command labels are visible.
    16                              <1> ;==============================================================================
    17                              <1> 
    18                              <1> ; ── Configuration ─────────────────────────────────────────────────────────────
    19                              <1> HISTORY_DEPTH   equ 4           ; number of remembered commands
    20                              <1> LINE_MAX        equ 256         ; max input line length
    21                              <1> MAX_ARGS        equ 16          ; max args per command
    22                              <1> %define PROMPT_STR "vibix$ "     ; shell prompt (text macro, used in db below)
    23                              <1> 
    24                              <1> ; ── Main shell entry point ───────────────────────────────────────────────────
    25                              <1> ; Called from dispatch table. Never returns (loops until 'exit' builtin).
    26                              <1> ; Input: rdi = argc, rsi = argv, rdx = envp
    27                              <1> shell:
    28                              <1>     ; Reset stack to top of user stack page
    29 00000837 BC00300002          <1>     mov rsp, 0x2003000
    30                              <1> 
    31 0000083C 53                  <1>     push rbx
    32 0000083D 4154                <1>     push r12
    33 0000083F 4155                <1>     push r13
    34 00000841 4156                <1>     push r14
    35 00000843 4157                <1>     push r15
    36                              <1> 
    37                              <1>     ; Save envp for printenv builtin
    38 00000845 4989D7              <1>     mov r15, rdx                    ; r15 = envp (may be NULL)
    39                              <1> 
    40                              <1>     ; Zero-initialize history
    41 00000848 31C0                <1>     xor eax, eax
    42 0000084A 488D3D470B0000      <1>     lea rdi, [rel history_buf]
    43 00000851 B900040000          <1>     mov ecx, HISTORY_DEPTH * LINE_MAX
    44 00000856 F3AA                <1>     rep stosb
    45                              <1> 
    46                              <1>     ; Initialize history count
    47 00000858 48C705350F00000000- <1>     mov qword [rel history_count], 0
    47 00000861 0000                <1>
    48 00000863 48C705320F00000000- <1>     mov qword [rel history_index], 0
    48 0000086C 0000                <1>
    49                              <1> 
    50                              <1>     ; ── Welcome banner ──────────────────────────────────────────────────────
    51 0000086E 488D359E060000      <1>     lea rsi, [rel str_welcome]
    52 00000875 BF01000000          <1>     mov rdi, 1
    53 0000087A E8CDFBFFFF          <1>     call write_str
    54 0000087F E8FFFBFFFF          <1>     call write_newline
    55 00000884 E8FAFBFFFF          <1>     call write_newline
    56                              <1> 
    57                              <1> ; ── Main read-eval-print loop ────────────────────────────────────────────────
