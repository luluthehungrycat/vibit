   229                              <1> ; readline(buf, max_len) — Read line with editing and history
   230                              <1> ;
   231                              <1> ; Input:  rdi = buffer address, esi = max length
   232                              <1> ; Output: rax = line length (0 for empty/EOF)
   233                              <1> ;
   234                              <1> ; Features:
   235                              <1> ;   - Echoes printable characters
   236                              <1> ;   - Backspace (0x7F or 0x08) deletes last character
   237                              <1> ;   - Ctrl+D on empty line → exit shell
   238                              <1> ;   - Up arrow (ESC [ A) / Down arrow (ESC [ B) for history
   239                              <1> ;   - Enter (0x0D) submits line
   240                              <1> ;==============================================================================
   241                              <1> readline:
   242 00000A86 53                  <1>     push rbx
   243 00000A87 4154                <1>     push r12
   244 00000A89 4155                <1>     push r13
   245 00000A8B 4156                <1>     push r14
   246 00000A8D 4157                <1>     push r15
   247                              <1> 
   248 00000A8F 4989FC              <1>     mov r12, rdi                    ; r12 = buffer
   249 00000A92 4189F5              <1>     mov r13d, esi                   ; r13 = max length
   250 00000A95 4531F6              <1>     xor r14d, r14d                  ; r14 = current position (offset in buf)
   251                              <1> 
   252                              <1>     ; Reset history browse position to end
   253 00000A98 4C8B3DF90C0000      <1>     mov r15, [rel history_count]    ; r15 = history browse index
   254                              <1> 
   255                              <1> .readline_loop:
   256                              <1>     ; Read one byte from stdin
   257 00000A9F 4883EC10            <1>     sub rsp, 16
   258 00000AA3 BF00000000          <1>     mov rdi, 0                      ; fd = stdin
   259 00000AA8 4889E6              <1>     mov rsi, rsp                    ; buffer on stack
   260 00000AAB BA01000000          <1>     mov rdx, 1                      ; 1 byte
   261 00000AB0 B802000000          <1>     mov rax, 2                      ; SYS_READ
   262 00000AB5 0F05                <1>     syscall
   263 00000AB7 4883C410            <1>     add rsp, 16
   264                              <1> 
   265 00000ABB 4885C0              <1>     test rax, rax
   266 00000ABE 0F8E95010000        <1>     jle .eof                        ; EOF or error → end of input
   267                              <1> 
   268 00000AC4 8A4424F0            <1>     mov al, [rsp - 16]              ; reload the byte we read
   269                              <1> 
   270                              <1>     ; ── Handle Enter (0x0D) ────────────────────────────────────────────────
   271 00000AC8 3C0D                <1>     cmp al, 0x0D
   272 00000ACA 0F8419010000        <1>     je .enter
   273                              <1> 
   274                              <1>     ; ── Handle Ctrl+D ───────────────────────────────────────────────────────
   275 00000AD0 3C04                <1>     cmp al, 0x04
