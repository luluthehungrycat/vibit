   512 00000CBC 4189C6              <1>     mov r14d, eax                   ; r14 = new length
   513                              <1> 
   514                              <1>     ; Display the history entry text
   515 00000CBF 4C89E6              <1>     mov rsi, r12
   516 00000CC2 BF01000000          <1>     mov rdi, 1
   517 00000CC7 E880F7FFFF          <1>     call write_str
   518                              <1> 
   519                              <1> .hd_done:
   520 00000CCC 5A                  <1>     pop rdx
   521 00000CCD 5E                  <1>     pop rsi
   522 00000CCE 5F                  <1>     pop rdi
   523 00000CCF 59                  <1>     pop rcx
   524 00000CD0 58                  <1>     pop rax
   525 00000CD1 C3                  <1>     ret
