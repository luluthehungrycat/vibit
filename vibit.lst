   141                              <1> ; ── Poweroff/reboot builtins (VIBIT shutdown IPC) ─────────────────────────
   142                              <1> ; These set the shared-memory shutdown_flag and then exit.
   143                              <1> ; PID 1 (init) checks shutdown_flag in reaper loop → calls poweroff/reboot.
   144                              <1> .check_poweroff:
   145 00000972 488D35D8050000      <1>     lea rsi, [rel str_poweroff_cmd]
   146 00000979 E860050000          <1>     call strcmp
   147 0000097E 4885C0              <1>     test rax, rax
   148 00000981 7525                <1>     jnz .check_reboot
   149 00000983 C705B7FAFFFF020000- <1>     mov dword [rel shutdown_flag], SHUTDOWN_POWEROFF
   149 0000098C 00                  <1>
   150 0000098D 488D35CD050000      <1>     lea rsi, [rel str_poweroff_msg]
   151 00000994 BF01000000          <1>     mov rdi, 1
   152 00000999 E8AEFAFFFF          <1>     call write_str
   153 0000099E E8E0FAFFFF          <1>     call write_newline
   154 000009A3 E9BF000000          <1>     jmp .exit_shell
   155                              <1> 
   156                              <1> .check_reboot:
   157 000009A8 488D35AB050000      <1>     lea rsi, [rel str_reboot_cmd]
   158 000009AF E82A050000          <1>     call strcmp
   159 000009B4 4885C0              <1>     test rax, rax
   160 000009B7 7525                <1>     jnz .check_empty
