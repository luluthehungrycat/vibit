   277                              <1> 
   278                              <1>     ; ── Handle Backspace (0x7F or 0x08) ────────────────────────────────────
   279 00000AD8 3C7F                <1>     cmp al, 0x7F
   280 00000ADA 7434                <1>     je .backspace
   281 00000ADC 3C08                <1>     cmp al, 0x08
   282 00000ADE 7430                <1>     je .backspace
   283                              <1> 
   284                              <1>     ; ── Handle Escape sequences (arrow keys) ────────────────────────────────
   285 00000AE0 3C1B                <1>     cmp al, 0x1B
   286 00000AE2 746B                <1>     je .escape_seq
   287                              <1> 
   288                              <1>     ; ── Handle regular printable characters ─────────────────────────────────
   289 00000AE4 3C20                <1>     cmp al, 0x20                    ; space
   290 00000AE6 72B7                <1>     jb .readline_loop               ; ignore other control chars
   291 00000AE8 3C7E                <1>     cmp al, 0x7E                    ; DEL (handled above) and beyond
   292 00000AEA 77B3                <1>     ja .readline_loop
   293                              <1> 
   294                              <1>     ; Check if buffer is full
   295 00000AEC 4539EE              <1>     cmp r14d, r13d
   296 00000AEF 73AE                <1>     jae .readline_loop
   297                              <1> 
   298                              <1>     ; Store character
   299 00000AF1 43880434            <1>     mov [r12 + r14], al
   300 00000AF5 41FFC6              <1>     inc r14d
   301                              <1> 
   302                              <1>     ; Echo character back
   303 00000AF8 50                  <1>     push rax
   304 00000AF9 BF01000000          <1>     mov rdi, 1                      ; STDOUT
   305 00000AFE 4889E6              <1>     mov rsi, rsp                    ; byte on stack
   306 00000B01 BA01000000          <1>     mov rdx, 1
   307 00000B06 B801000000          <1>     mov rax, 1                      ; SYS_WRITE
   308 00000B0B 0F05                <1>     syscall
   309 00000B0D 58                  <1>     pop rax
   310                              <1> 
   311 00000B0E EB8F                <1>     jmp .readline_loop
   312                              <1> 
   313                              <1> .backspace:
   314 00000B10 4585F6              <1>     test r14d, r14d
   315 00000B13 748A                <1>     jz .readline_loop               ; nothing to delete
   316                              <1> 
   317 00000B15 41FFCE              <1>     dec r14d                        ; move position back
   318                              <1> 
   319                              <1>     ; Send backspace: move left, overwrite with space, move left again
   320                              <1>     ; Sequence: 0x08 ' ' 0x08
   321 00000B18 50                  <1>     push rax
   322 00000B19 53                  <1>     push rbx
   323 00000B1A C6042408            <1>     mov byte [rsp], 0x08
   324 00000B1E BF01000000          <1>     mov rdi, 1
   325 00000B23 4889E6              <1>     mov rsi, rsp
   326 00000B26 BA01000000          <1>     mov rdx, 1
   327 00000B2B B801000000          <1>     mov rax, 1                      ; SYS_WRITE
   328 00000B30 0F05                <1>     syscall
   329                              <1> 
   330 00000B32 C6042420            <1>     mov byte [rsp], 0x20            ; space
   331 00000B36 B801000000          <1>     mov rax, 1
   332 00000B3B 0F05                <1>     syscall
   333                              <1> 
   334 00000B3D C6042408            <1>     mov byte [rsp], 0x08            ; backspace again
   335 00000B41 B801000000          <1>     mov rax, 1
   336 00000B46 0F05                <1>     syscall
   337 00000B48 5B                  <1>     pop rbx
   338 00000B49 58                  <1>     pop rax
   339                              <1> 
   340 00000B4A E950FFFFFF          <1>     jmp .readline_loop
   341                              <1> 
   342                              <1> .escape_seq:
   343                              <1>     ; Read next two bytes (ESC [ A/B/C/D)
   344 00000B4F 4883EC10            <1>     sub rsp, 16
   345                              <1> .read_esc_1:
   346 00000B53 BF00000000          <1>     mov rdi, 0
   347 00000B58 4889E6              <1>     mov rsi, rsp
   348 00000B5B BA01000000          <1>     mov rdx, 1
   349 00000B60 B802000000          <1>     mov rax, 2                      ; SYS_READ
   350 00000B65 0F05                <1>     syscall
   351 00000B67 4885C0              <1>     test rax, rax
   352 00000B6A 7E2B                <1>     jle .esc_done
   353 00000B6C 8A0424              <1>     mov al, [rsp]
   354 00000B6F 3C5B                <1>     cmp al, '['                     ; CSI
   355 00000B71 7524                <1>     jne .esc_done
   356                              <1> .read_esc_2:
   357 00000B73 BF00000000          <1>     mov rdi, 0
   358 00000B78 4889E6              <1>     mov rsi, rsp
   359 00000B7B BA01000000          <1>     mov rdx, 1
   360 00000B80 B802000000          <1>     mov rax, 2                      ; SYS_READ
   361 00000B85 0F05                <1>     syscall
   362 00000B87 4885C0              <1>     test rax, rax
   363 00000B8A 7E0B                <1>     jle .esc_done
   364 00000B8C 8A0424              <1>     mov al, [rsp]
   365 00000B8F 3C41                <1>     cmp al, 'A'                     ; Up arrow
   366 00000B91 740D                <1>     je .history_up
   367 00000B93 3C42                <1>     cmp al, 'B'                     ; Down arrow
   368 00000B95 7431                <1>     je .history_down
   369                              <1>     ; Ignore other arrow keys (C=right, D=left)
   370                              <1> .esc_done:
   371 00000B97 4883C410            <1>     add rsp, 16
   372 00000B9B E9FFFEFFFF          <1>     jmp .readline_loop
   373                              <1> 
   374                              <1> .history_up:
   375 00000BA0 4883C410            <1>     add rsp, 16                     ; clean up esc read stack
   376                              <1>     ; Check if there's history to browse
   377 00000BA4 48833DEC0B000000    <1>     cmp qword [rel history_count], 0
   378 00000BAC 0F84EDFEFFFF        <1>     je .readline_loop
   379                              <1>     ; Decrement browse index (earlier in history)
   380 00000BB2 4585FF              <1>     test r15d, r15d
   381 00000BB5 0F84E4FEFFFF        <1>     jz .readline_loop               ; already at oldest
   382 00000BBB 41FFCF              <1>     dec r15d
   383 00000BBE E8A2000000          <1>     call history_display
   384 00000BC3 E9D7FEFFFF          <1>     jmp .readline_loop
   385                              <1> 
   386                              <1> .history_down:
   387 00000BC8 4883C410            <1>     add rsp, 16                     ; clean up esc read stack
   388                              <1>     ; Increment browse index (later in history)
   389 00000BCC 488B05C50B0000      <1>     mov rax, [rel history_count]
   390 00000BD3 4139C7              <1>     cmp r15d, eax
