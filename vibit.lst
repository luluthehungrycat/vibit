    59                              <1>     ; Print prompt: "vibix$ "
    60 00000889 488D357B060000      <1>     lea rsi, [rel str_prompt]
    61 00000890 BF01000000          <1>     mov rdi, 1
    62 00000895 E8B2FBFFFF          <1>     call write_str
    63                              <1> 
    64                              <1>     ; ── Read a line with editing and history ────────────────────────────────
    65 0000089A 488D3D77090000      <1>     lea rdi, [rel input_line]
    66 000008A1 BE00010000          <1>     mov esi, LINE_MAX
    67 000008A6 E8DB010000          <1>     call readline
    68 000008AB 4989C4              <1>     mov r12, rax                    ; r12 = line length
    69                              <1> 
    70                              <1>     ; Empty line → reprompt
    71 000008AE 4D85E4              <1>     test r12, r12
