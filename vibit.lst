   527                              <1> ;==============================================================================
   528                              <1> ; history_add(line) — Add a line to the command history
   529                              <1> ;
   530                              <1> ; Input: rdi = null-terminated string
   531                              <1> ;==============================================================================
   532                              <1> history_add:
   533 00000CD2 53                  <1>     push rbx
   534 00000CD3 4154                <1>     push r12
   535 00000CD5 4155                <1>     push r13
   536 00000CD7 4156                <1>     push r14
   537                              <1> 
   538 00000CD9 4989FC              <1>     mov r12, rdi                    ; r12 = line
   539 00000CDC E894F7FFFF          <1>     call strlen
   540 00000CE1 4989C5              <1>     mov r13, rax                    ; r13 = line length
   541                              <1> 
   542                              <1>     ; Don't add duplicate of last entry
   543 00000CE4 48833DAC0A000000    <1>     cmp qword [rel history_count], 0
   544 00000CEC 7428                <1>     je .ha_do_add
   545                              <1> 
   546                              <1>     ; Get last history entry
   547 00000CEE 488B05A30A0000      <1>     mov rax, [rel history_count]
   548 00000CF5 48FFC8              <1>     dec rax
   549 00000CF8 B900010000          <1>     mov ecx, LINE_MAX
   550 00000CFD F7E1                <1>     mul ecx
   551 00000CFF 4C8DB0[98130000]    <1>     lea r14, [rel history_buf + rax] ; r14 = last entry
   551          ******************  <1>  warning: indirect address displacements cannot be RIP-relative [-w+other]
   552                              <1> 
   553                              <1>     ; Compare with current line
   554 00000D06 4C89E7              <1>     mov rdi, r12
   555 00000D09 4C89F6              <1>     mov rsi, r14
   556 00000D0C E8CD010000          <1>     call strcmp
   557 00000D11 4885C0              <1>     test rax, rax
   558 00000D14 7460                <1>     jz .ha_done                     ; duplicate, skip
   559                              <1> 
   560                              <1> .ha_do_add:
   561                              <1>     ; Check if we need to shift (history full)
   562 00000D16 488B057B0A0000      <1>     mov rax, [rel history_count]
   563 00000D1D 4883F804            <1>     cmp rax, HISTORY_DEPTH
   564 00000D21 7221                <1>     jb .ha_no_shift
   565                              <1> 
   566                              <1>     ; Shift all entries up (remove oldest)
   567 00000D23 B900030000          <1>     mov ecx, (HISTORY_DEPTH - 1) * LINE_MAX
   568 00000D28 488D3D69060000      <1>     lea rdi, [rel history_buf]
   569 00000D2F 488D3562070000      <1>     lea rsi, [rel history_buf + LINE_MAX]
   570 00000D36 F3A4                <1>     rep movsb
   571 00000D38 B803000000          <1>     mov rax, HISTORY_DEPTH - 1
   572 00000D3D 488905540A0000      <1>     mov [rel history_count], rax
   573                              <1> 
   574                              <1> .ha_no_shift:
   575                              <1>     ; Append new entry
   576 00000D44 488B054D0A0000      <1>     mov rax, [rel history_count]
   577 00000D4B B900010000          <1>     mov ecx, LINE_MAX
   578 00000D50 F7E1                <1>     mul ecx
   579 00000D52 488DB8[98130000]    <1>     lea rdi, [rel history_buf + rax] ; rdi = destination slot
   579          ******************  <1>  warning: indirect address displacements cannot be RIP-relative [-w+other]
   580                              <1> 
   581                              <1>     ; Copy line into history
   582 00000D59 4C89E6              <1>     mov rsi, r12
   583 00000D5C E894010000          <1>     call strcpy
   584                              <1> 
   585                              <1>     ; Increment count
   586 00000D61 48FF05300A0000      <1>     inc qword [rel history_count]
   587                              <1> 
   588                              <1>     ; Reset browse position
   589 00000D68 488B05290A0000      <1>     mov rax, [rel history_count]
   590 00000D6F 4889052A0A0000      <1>     mov [rel history_index], rax
   591                              <1> 
   592                              <1> .ha_done:
   593 00000D76 415E                <1>     pop r14
   594 00000D78 415D                <1>     pop r13
   595 00000D7A 415C                <1>     pop r12
   596 00000D7C 5B                  <1>     pop rbx
   597 00000D7D C3                  <1>     ret
   598                              <1> 
