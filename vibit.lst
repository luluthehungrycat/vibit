     1                                  ;==============================================================================
     2                                  ; vibit.asm — VIBIT: VIBIX Init and Service Manager (PID 1)
     3                                  ;
     4                                  ; Version 0.2.0
     5                                  ;
     6                                  ; Architecture:
     7                                  ;   _start → getpid() → PID 1: spawn services, reaper loop with respawn
     8                                  ;                      → non-PID-1: dispatch via r12 to service function
     9                                  ;
    10                                  ; Service dispatch via r12 convention:
    11                                  ;   Parent sets r12 = SERVICE_ID before sys_fork.
    12                                  ;   r12 is preserved through fork (kernel copies register state).
    13                                  ;   Child reads r12 → dispatches to function from service table.
    14                                  ;
    15                                  ; Shutdown IPC:
    16                                  ;   Shell writes to shutdown_flag in shared address space
    17                                  ;   (no per-process page tables in VIBIX — all processes share same map).
    18                                  ;   PID 1 checks flag on each iteration of reaper loop.
    19                                  ;
    20                                  ; Build:
    21                                  ;   nasm -f bin -o vibit.bin vibit.asm -I ./
    22                                  ;
    23                                  ; For VIBIX integration, copy vibit.bin as userspace/vibix_blob.bin.
    24                                  ;==============================================================================
    25                                  
    26                                  ; ── Assembler directives ──────────────────────────────────────────────────────
    27                                  default rel
    28                                  ORG 0x2000000
    29                                  bits 64
    30                                  
    31                                  ;==============================================================================
    32                                  ; Syscall numbers (VIBIX kernel ABI)
    33                                  ;==============================================================================
    34                                  SYS_EXIT       equ 0
    35                                  SYS_WRITE      equ 1
    36                                  SYS_READ       equ 2
    37                                  SYS_GETPID     equ 3
    38                                  SYS_NANOSLEEP  equ 5
    39                                  SYS_REBOOT     equ 7
    40                                  SYS_FORK       equ 8
    41                                  SYS_EXEC       equ 9
    42                                  SYS_WAITPID    equ 10
    43                                  
    44                                  ;==============================================================================
    45                                  ; Reboot magic constants (Linux-compatible, VIBIX syscall 7)
    46                                  ;==============================================================================
    47                                  REBOOT_MAGIC    equ 0xfee1dead
    48                                  REBOOT_MAGIC2   equ 0x28121969
    49                                  REBOOT_POWEROFF equ 0x4321fedc
    50                                  REBOOT_RESTART  equ 0xcdef0123
    51                                  
    52                                  ;==============================================================================
    53                                  ; Shutdown flag values — written by child processes, polled by PID 1
    54                                  ;==============================================================================
    55                                  SHUTDOWN_NONE     equ 0
    56                                  SHUTDOWN_REBOOT   equ 1
    57                                  SHUTDOWN_POWEROFF equ 2
    58                                  
    59                                  ;==============================================================================
    60                                  ; Service descriptor structure (3 qwords per entry)
    61                                  ;==============================================================================
    62                                  SVC_FUNC  equ 0         ; entry function pointer
    63                                  SVC_NAME  equ 8         ; name string pointer
    64                                  SVC_FLAGS equ 16        ; flags (bit 0 = respawn on exit)
    65                                  SVC_SIZE  equ 24
    66                                  
    67                                  ;==============================================================================
    68                                  ; Service IDs
    69                                  ;==============================================================================
    70                                  SVC_INIT  equ 0         ; PID 1 boot task (not spawned as child)
    71                                  SVC_SHELL equ 1         ; Interactive shell (respawnable)
    72                                  
    73                                  ;==============================================================================
    74                                  ; Code section
    75                                  ;==============================================================================
    76                                  section .text
    77                                  global _start
    78                                  
    79                                  ;==============================================================================
    80                                  ; _start — entry point (initial boot and exec restart)
    81                                  ;
    82                                  ; Initial boot (PID 1):  init banner, run init tasks, spawn services, reaper
    83                                  ; Child process:         dispatch via r12 to service function
    84                                  ;==============================================================================
    85                                  _start:
    86 00000000 B803000000                  mov rax, SYS_GETPID
    87 00000005 0F05                        syscall
    88                                  
    89 00000007 4883F801                    cmp rax, 1
    90 0000000B 7423                        je .init
    91                                  
    92                                      ; ── Child process dispatch ──
    93                                      ; r12 = service_id (set by parent before fork, preserved through fork)
    94                                      ; After exec(): kernel resets RIP to 0x2000000, but user registers
    95                                      ; (including r12) are preserved from the exec'ing process.  If r12
    96                                      ; is out of range OR equals SVC_INIT (0, reserved for PID 1), we
    97                                      ; fall through to the default shell service.
    98 0000000D 4983FC02                    cmp r12, svc_count
    99 00000011 7305                        jae .set_shell_fallback
   100 00000013 4D85E4                      test r12, r12                   ; SVC_INIT (0) is PID 1 only
   101 00000016 7506                        jnz .do_dispatch
   102                                  .set_shell_fallback:
   103 00000018 41BC01000000                mov r12, SVC_SHELL              ; fallback to shell
   104                                  .do_dispatch:
   105 0000001E BC00300002                  mov rsp, 0x2003000              ; fresh stack for service
   106 00000023 496BDC18                    imul rbx, r12, SVC_SIZE         ; rbx = service_id * 24
   107 00000027 488B83[62000000]            mov rax, [svc_table + rbx + SVC_FUNC]
   108 0000002E FFE0                        jmp rax                         ; jump to service (never returns)
   109                                  
   110                                  .init:
   111                                      ; ── Init (PID 1) ──
   112 00000030 48C705090400000000-         mov qword [rel shutdown_flag], SHUTDOWN_NONE
   112 00000039 0000               
   113                                  
   114 0000003B 488D35CB020000              lea rsi, [str_banner]
   115 00000042 E833020000                  call print
   116                                  
   117                                      ; Run the init boot task (one-shot, returns)
   118 00000047 E846000000                  call service_init
   119                                  
   120                                      ; Spawn all services as child processes
   121 0000004C E86B000000                  call spawn_all
   122                                  
   123                                      ; Enter reaper loop (blocks on waitpid, never returns)
   124 00000051 488D35F6020000              lea rsi, [str_reaper]
   125 00000058 E81D020000                  call print
   126 0000005D E9D8000000                  jmp reaper_loop
   127                                  
   128                                  ;==============================================================================
   129                                  ; Service table — defines all runnable services
   130                                  ;==============================================================================
   131                                  svc_table:
   132 00000062 [9200000000000000]-         dq service_init,  str_svc_init,  0    ; SVC_INIT (PID 1 internal)
   132 0000006A [E403000000000000]-
   132 00000072 0000000000000000   
   133 0000007A [9F00000000000000]-         dq service_shell, str_svc_shell, 1    ; SVC_SHELL (respawnable)
   133 00000082 [E903000000000000]-
   133 0000008A 0100000000000000   
   134                                  svc_count equ ($ - svc_table) / SVC_SIZE
   135                                  
   136                                  ;==============================================================================
   137                                  ; service_init — one-shot boot task (runs as part of PID 1 init sequence)
   138                                  ;
   139                                  ; Returns to caller.  In production this would mount filesystems,
   140                                  ; set up devices, etc.  Currently a placeholder.
   141                                  ;==============================================================================
   142                                  service_init:
   143 00000092 488D3556030000              lea rsi, [str_svc_init_msg]
   144 00000099 E8DC010000                  call print
   145 0000009E C3                          ret
   146                                  
   147                                  ;==============================================================================
   148                                  ; service_shell — launch interactive shell as child
   149                                  ;
   150                                  ; Called in child process context (after fork).  Jumps to shell entry,
   151                                  ; which never returns (shell calls exit() on "exit" command).
   152                                  ;==============================================================================
   153                                  service_shell:
   154 0000009F 488D3564030000              lea rsi, [str_svc_shell_msg]
   155 000000A6 E8CF010000                  call print
   156 000000AB 488D351E040000              lea rsi, [str_newline]
   157 000000B2 E8C3010000                  call print
   158 000000B7 E97B070000                  jmp shell                           ; defined in vibix_shell.inc
   159                                  
   160                                  ;==============================================================================
   161                                  ; spawn_all — fork a child for every spawnable service in svc_table
   162                                  ;
   163                                  ; Skips SVC_INIT (PID 1 runs it directly).  For each other service:
   164                                  ;   set r12 = service_id
   165                                  ;   fork
   166                                  ;   parent: continue to next service
   167                                  ;   child:  reset stack, dispatch to service function
   168                                  ;==============================================================================
   169                                  spawn_all:
   170 000000BC 53                          push rbx
   171 000000BD 4154                        push r12
   172                                  
   173 000000BF 4531E4                      xor r12d, r12d
   174                                  .loop:
   175 000000C2 4983FC02                    cmp r12, svc_count
   176 000000C6 736E                        jae .done
   177                                  
   178                                      ; Skip SVC_INIT (it's for PID 1, not a child process)
   179 000000C8 4D85E4                      test r12, r12
   180 000000CB 7464                        jz .next
   181                                  
   182                                      ; Announce spawn
   183 000000CD 488D3553020000              lea rsi, [str_spawn]
   184 000000D4 E8A1010000                  call print
   185 000000D9 496BCC18                    imul rcx, r12, SVC_SIZE         ; rcx = service_id * 24
   186 000000DD 488BB1[6A000000]            mov rsi, [svc_table + rcx + SVC_NAME]
   187 000000E4 E891010000                  call print
   188                                  
   189                                      ; Save current service_id to global for the child.
   190                                      ; VIBIX fork zeros all user registers in the child frame, so r12
   191                                      ; won't survive the syscall.  The child reads spawn_id to dispatch.
   192 000000E9 4C89254C030000              mov [rel spawn_id], r12
   193                                  
   194 000000F0 B808000000                  mov rax, SYS_FORK
   195 000000F5 0F05                        syscall
   196                                  
   197 000000F7 4885C0                      test rax, rax
   198 000000FA 7410                        jz .child                           ; child: rax = 0
   199 000000FC 7C27                        jl .error                           ; error: rax < 0
   200                                  
   201                                      ; Parent: announce success
   202 000000FE 488D3533020000              lea rsi, [str_done]
   203 00000105 E870010000                  call print
   204 0000010A EB25                        jmp .next
   205                                  
   206                                  .child:
   207 0000010C BC00300002                  mov rsp, 0x2003000
   208 00000111 4C8B2524030000              mov r12, [rel spawn_id]             ; restore service_id (fork zeros r12)
   209 00000118 496BDC18                    imul rbx, r12, SVC_SIZE            ; rbx = service_id * 24
   210 0000011C 488B83[62000000]            mov rax, [svc_table + rbx + SVC_FUNC]
   211 00000123 FFE0                        jmp rax                             ; never returns
   212                                  
   213                                  .error:
   214 00000125 488D3516020000              lea rsi, [str_fail]
   215 0000012C E849010000                  call print
   216                                  
   217                                  .next:
   218 00000131 49FFC4                      inc r12
   219 00000134 EB8C                        jmp .loop
   220                                  
   221                                  .done:
   222 00000136 415C                        pop r12
   223 00000138 5B                          pop rbx
   224 00000139 C3                          ret
   225                                  
   226                                  ;==============================================================================
   227                                  ; reaper_loop — infinite waitpid(-1) loop with respawn and shutdown
   228                                  ;
   229                                  ; On each child exit:
   230                                  ;   1. Reap the zombie
   231                                  ;   2. Check shutdown flag (child may have set it)
   232                                  ;   3. If flag set → poweroff or reboot
   233                                  ;   4. If shell exited → respawn a new instance
   234                                  ;
   235                                  ; waitpid detail: RAX=0 when blocked parent resumes (kernel limitation).
   236                                  ; We just retry the waitpid.
   237                                  ;==============================================================================
   238                                  reaper_loop:
   239                                  .loop:
   240                                      ; Check shutdown flag (non-blocking poll before waitpid)
   241 0000013A 4C8B0503030000              mov r8, [rel shutdown_flag]
   242 00000141 4D85C0                      test r8, r8
   243 00000144 0F85BD000000                jnz .shutdown
   244                                  
   245                                      ; waitpid(-1, NULL, 0) — blocks until a child exits
   246 0000014A B80A000000                  mov rax, SYS_WAITPID
   247 0000014F 31FF                        xor edi, edi
   248 00000151 48FFCF                      dec rdi                         ; pid = -1 (any child)
   249 00000154 31F6                        xor esi, esi                    ; wstatus = NULL
   250 00000156 31D2                        xor edx, edx                    ; flags = 0 (blocking)
   251 00000158 0F05                        syscall
   252                                  
   253 0000015A 4883F8FF                    cmp rax, -1
   254 0000015E 0F8484000000                je .no_children
   255                                  
   256 00000164 4885C0                      test rax, rax
   257 00000167 74D1                        jz .loop                        ; RAX=0: was blocked, retry
   258                                  
   259                                      ; ── Reaped child PID in rax ──
   260 00000169 50                          push rax
   261 0000016A 488D35F1010000              lea rsi, [str_reaped]
   262 00000171 E804010000                  call print
   263 00000176 58                          pop rax
   264 00000177 E82A010000                  call print_decimal
   265 0000017C 488D354D030000              lea rsi, [str_newline]
   266 00000183 E8F2000000                  call print
   267                                  
   268                                      ; Check shutdown flag (child may have set it before exiting)
   269 00000188 4C8B05B5020000              mov r8, [rel shutdown_flag]
   270 0000018F 4D85C0                      test r8, r8
   271 00000192 7573                        jnz .shutdown
   272                                  
   273                                      ; Respawn shell
   274 00000194 488D35DC010000              lea rsi, [str_respawn]
   275 0000019B E8DA000000                  call print
   276                                  
   277 000001A0 41BC01000000                mov r12, SVC_SHELL
   278 000001A6 B808000000                  mov rax, SYS_FORK
   279 000001AB 0F05                        syscall
   280                                  
   281 000001AD 4885C0                      test rax, rax
   282 000001B0 7413                        jz .child_respawn
   283 000001B2 7C23                        jl .respawn_error
   284                                  
   285 000001B4 488D357D010000              lea rsi, [str_done]
   286 000001BB E8BA000000                  call print
   287 000001C0 E975FFFFFF                  jmp .loop
   288                                  
   289                                  .child_respawn:
   290                                      ; Dispatch through the service table — same path as spawn_all's children.
   291                                      ; r12 = SVC_SHELL was set before fork above, but we load from the table
   292                                      ; directly for clarity and to keep the dispatch logic in one place.
   293 000001C5 BC00300002                  mov rsp, 0x2003000
   294 000001CA 488D1D91FEFFFF              lea rbx, [svc_table]
   295 000001D1 488B4318                    mov rax, [rbx + SVC_SHELL * SVC_SIZE + SVC_FUNC]
   296 000001D5 FFE0                        jmp rax
   297                                  
   298                                  .respawn_error:
   299 000001D7 488D35B4010000              lea rsi, [str_respawn_fail]
   300 000001DE E897000000                  call print
   301 000001E3 E952FFFFFF                  jmp .loop
   302                                  
   303                                  .no_children:
   304 000001E8 488D35BA010000              lea rsi, [str_none]
   305 000001EF E886000000                  call print
   306                                      ; nanosleep(1, 0) — wait a bit before retrying
   307 000001F4 B805000000                  mov rax, SYS_NANOSLEEP
   308 000001F9 BF01000000                  mov rdi, 1
   309 000001FE 31F6                        xor esi, esi
   310 00000200 0F05                        syscall
   311 00000202 E933FFFFFF                  jmp .loop
   312                                  
   313                                  .shutdown:
   314 00000207 488D3513020000              lea rsi, [str_shutdown_msg]
   315 0000020E E867000000                  call print
   316 00000213 4C8B052A020000              mov r8, [rel shutdown_flag]
   317 0000021A 4983F801                    cmp r8, SHUTDOWN_REBOOT
   318 0000021E 740A                        je .do_reboot
   319 00000220 E80F000000                  call poweroff
   320 00000225 E910FFFFFF                  jmp .loop
   321                                  .do_reboot:
   322 0000022A E828000000                  call reboot
   323 0000022F E906FFFFFF                  jmp .loop
   324                                  
   325                                  ;==============================================================================
   326                                  ; poweroff — syscall 7 with REBOOT_POWEROFF
   327                                  ;==============================================================================
   328                                  poweroff:
   329 00000234 488D3589010000              lea rsi, [str_poweroff]
   330 0000023B E83A000000                  call print
   331 00000240 B807000000                  mov rax, SYS_REBOOT
   332 00000245 BFADDEE1FE                  mov rdi, REBOOT_MAGIC
   333 0000024A BE69191228                  mov rsi, REBOOT_MAGIC2
   334 0000024F BADCFE2143                  mov rdx, REBOOT_POWEROFF
   335 00000254 0F05                        syscall
   336 00000256 C3                          ret
   337                                  
   338                                  ;==============================================================================
   339                                  ; reboot — syscall 7 with REBOOT_RESTART
   340                                  ;==============================================================================
   341                                  reboot:
   342 00000257 488D3577010000              lea rsi, [str_reboot]
   343 0000025E E817000000                  call print
   344 00000263 B807000000                  mov rax, SYS_REBOOT
   345 00000268 BFADDEE1FE                  mov rdi, REBOOT_MAGIC
   346 0000026D BE69191228                  mov rsi, REBOOT_MAGIC2
   347 00000272 BA2301EFCD                  mov rdx, REBOOT_RESTART
   348 00000277 0F05                        syscall
   349 00000279 C3                          ret
   350                                  
   351                                  ;==============================================================================
   352                                  ; print — write null-terminated string to stdout
   353                                  ;
   354                                  ; IN:  rsi = pointer to null-terminated string
   355                                  ; OUT: (none)
   356                                  ; CLOBBERS: rax, rcx, rdx, r11
   357                                  ;==============================================================================
   358                                  print:
   359 0000027A 53                          push rbx
   360 0000027B 4154                        push r12
   361 0000027D 4155                        push r13
   362 0000027F 4156                        push r14
   363 00000281 4157                        push r15
   364 00000283 56                          push rsi                        ; save string pointer for syscall
   365 00000284 4889F7                      mov rdi, rsi                    ; strlen expects rdi
   366 00000287 E8E9010000                  call strlen
   367 0000028C 4889C2                      mov rdx, rax                    ; length
   368 0000028F 5E                          pop rsi                         ; restore string pointer
   369 00000290 B801000000                  mov rax, SYS_WRITE
   370 00000295 BF01000000                  mov rdi, 1                      ; stdout
   371 0000029A 0F05                        syscall
   372 0000029C 415F                        pop r15
   373 0000029E 415E                        pop r14
   374 000002A0 415D                        pop r13
   375 000002A2 415C                        pop r12
   376 000002A4 5B                          pop rbx
   377 000002A5 C3                          ret
   378                                  
   379                                  ;==============================================================================
   380                                  ; print_decimal — print unsigned 64-bit decimal to stdout
   381                                  ;
   382                                  ; IN:  rax = value to print
   383                                  ; OUT: (none)
   384                                  ; CLOBBERS: rax, rcx, rdx, r11
   385                                  ;==============================================================================
   386                                  print_decimal:
   387 000002A6 53                          push rbx
   388 000002A7 4154                        push r12
   389 000002A9 4155                        push r13
   390 000002AB 4156                        push r14
   391 000002AD 4157                        push r15
   392 000002AF 4883EC18                    sub rsp, 24
   393 000002B3 4C8D6C2416                  lea r13, [rsp + 22]
   394 000002B8 41C6450100                  mov byte [r13 + 1], 0
   395 000002BD 4989C6                      mov r14, rax
   396 000002C0 41BF0A000000                mov r15, 10
   397                                  .convert:
   398 000002C6 31D2                        xor edx, edx
   399 000002C8 4C89F0                      mov rax, r14
   400 000002CB 49F7F7                      div r15
   401 000002CE 80C230                      add dl, '0'
   402 000002D1 41885500                    mov [r13], dl
   403 000002D5 49FFCD                      dec r13
   404 000002D8 4989C6                      mov r14, rax
   405 000002DB 4885C0                      test rax, rax
   406 000002DE 75E6                        jnz .convert
   407 000002E0 49FFC5                      inc r13
   408 000002E3 4C89EE                      mov rsi, r13
   409 000002E6 BF01000000                  mov rdi, 1
   410 000002EB E885010000                  call strlen
   411 000002F0 4889C2                      mov rdx, rax
   412 000002F3 B801000000                  mov rax, SYS_WRITE
   413 000002F8 BF01000000                  mov rdi, 1
   414 000002FD 0F05                        syscall
   415 000002FF 4883C418                    add rsp, 24
   416 00000303 415F                        pop r15
   417 00000305 415E                        pop r14
   418 00000307 415D                        pop r13
   419 00000309 415C                        pop r12
   420 0000030B 5B                          pop rbx
   421 0000030C C3                          ret
   422                                  
   423                                  ;==============================================================================
   424                                  ; String constants
   425                                  ;==============================================================================
   426 0000030D 56494249542076302E-     str_banner:        db "VIBIT v0.2.0: PID 1 init", 0x0A, 0
   426 00000316 322E303A2050494420-
   426 0000031F 3120696E69740A00   
   427 00000327 56494249543A207370-     str_spawn:         db "VIBIT: spawning ", 0
   427 00000330 61776E696E672000   
   428 00000338 202E2E2E646F6E650A-     str_done:          db " ...done", 0x0A, 0
   428 00000341 00                 
   429 00000342 202E2E2E6661696C65-     str_fail:          db " ...failed", 0x0A, 0
   429 0000034B 640A00             
   430 0000034E 56494249543A207265-     str_reaper:        db "VIBIT: reaper loop", 0x0A, 0
   430 00000357 61706572206C6F6F70-
   430 00000360 0A00               
   431 00000362 56494249543A207265-     str_reaped:        db "VIBIT: reaped child ", 0
   431 0000036B 61706564206368696C-
   431 00000374 642000             
   432 00000377 56494249543A207265-     str_respawn:       db "VIBIT: respawning shell...", 0
   432 00000380 737061776E696E6720-
   432 00000389 7368656C6C2E2E2E00 
   433 00000392 56494249543A207265-     str_respawn_fail:  db "VIBIT: respawn failed", 0x0A, 0
   433 0000039B 737061776E20666169-
   433 000003A4 6C65640A00         
   434 000003A9 56494249543A206E6F-     str_none:          db "VIBIT: no children (idle)", 0x0A, 0
   434 000003B2 206368696C6472656E-
   434 000003BB 202869646C65290A00 
   435 000003C4 56494249543A20706F-     str_poweroff:      db "VIBIT: poweroff", 0x0A, 0
   435 000003CD 7765726F66660A00   
   436 000003D5 56494249543A207265-     str_reboot:        db "VIBIT: reboot", 0x0A, 0
   436 000003DE 626F6F740A00       
   437 000003E4 696E697400              str_svc_init:      db "init", 0
   438 000003E9 7368656C6C00            str_svc_shell:     db "shell", 0
   439 000003EF 56494249543A20696E-     str_svc_init_msg:  db "VIBIT: init task complete", 0x0A, 0
   439 000003F8 6974207461736B2063-
   439 00000401 6F6D706C6574650A00 
   440 0000040A 56494249543A207374-     str_svc_shell_msg: db "VIBIT: starting shell", 0x0A, 0
   440 00000413 617274696E67207368-
   440 0000041C 656C6C0A00         
   441 00000421 56494249543A207368-     str_shutdown_msg:  db "VIBIT: shutdown requested", 0x0A, 0
   441 0000042A 7574646F776E207265-
   441 00000433 717565737465640A00 
   442                                  
   443                                  ; ── Spawn IPC (fork service_id passthrough) ──────────────────────────────────
   444                                  ; VIBIX fork zeros all user registers in the child's register frame.
   445                                  ; We save the service_id here before SYS_FORK so the child can read it.
   446 0000043C 0000000000000000        spawn_id: dq 0
   447                                  
   448                                  ; ── Shutdown IPC flag (protocol address for vish) ──────────────────────────
   449                                  ;
   450                                  ; Protocol:
   451                                  ;   Any process writes one of the SHUTDOWN_* values below to this flag.
   452                                  ;   PID 1 polls it on each iteration of the reaper loop (before and after
   453                                  ;   waitpid).  When non-zero, PID 1 prints the shutdown message and calls
   454                                  ;   sys_reboot with the appropriate magic.
   455                                  ;
   456                                  ;   Address: Fixed offset in the flat binary at 0x2000000.  Because VIBIX
   457                                  ;   has no per-process page tables, all processes share the same address
   458                                  ;   space — a write from any child is instantly visible to PID 1.
   459                                  ;
   460                                  ;   Values:  SHUTDOWN_NONE=0    (no action)
   461                                  ;            SHUTDOWN_REBOOT=1  (calls reboot → sys_reboot RESTART)
   462                                  ;            SHUTDOWN_POWEROFF=2 (calls poweroff → sys_reboot POWEROFF)
   463                                  ;
   464                                  ;   vish (vibix_shell.inc) writes to this via RIP-relative addressing:
   465                                  ;       mov dword [rel shutdown_flag], SHUTDOWN_POWEROFF
   466                                  ;       mov dword [rel shutdown_flag], SHUTDOWN_REBOOT
   467                                  ;
   468                                  ;   PID 1 reads it in reaper_loop:
