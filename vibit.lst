   760 00000EB2 415E                <1>     pop r14
   761 00000EB4 415D                <1>     pop r13
   762 00000EB6 415C                <1>     pop r12
   763 00000EB8 5B                  <1>     pop rbx
   764 00000EB9 C3                  <1>     ret
