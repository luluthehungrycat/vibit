   503 00000CA8 B900010000          <1>     mov ecx, LINE_MAX
   504 00000CAD F7E1                <1>     mul ecx
   505 00000CAF 4801C7              <1>     add rdi, rax                    ; rdi = history entry
   506                              <1> 
   507                              <1>     ; Copy history into buffer
