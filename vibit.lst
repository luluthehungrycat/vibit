   710 00000E3D 41803C2427          <1>     cmp byte [r12], 0x27            ; single quote
   711 00000E42 7422                <1>     je .pl_single_quote
   712 00000E44 EB40                <1>     jmp .pl_unquoted
   713                              <1> 
   714                              <1> .pl_double_quote:
   715 00000E46 49FFC4              <1>     inc r12                         ; skip opening "
   716                              <1> .dq_loop:
   717 00000E49 41803C2422          <1>     cmp byte [r12], '"'
   718 00000E4E 740C                <1>     je .dq_close
   719 00000E50 41803C2400          <1>     cmp byte [r12], 0
   720 00000E55 7456                <1>     je .pl_done
   721 00000E57 49FFC4              <1>     inc r12
   722 00000E5A EBED                <1>     jmp .dq_loop
   723                              <1> .dq_close:
   724 00000E5C 41C6042400          <1>     mov byte [r12], 0               ; null-terminate at closing "
   725 00000E61 49FFC4              <1>     inc r12
   726 00000E64 EBA8                <1>     jmp .pl_skip_ws
   727                              <1> 
   728                              <1> .pl_single_quote:
   729 00000E66 49FFC4              <1>     inc r12                         ; skip opening '
   730                              <1> .sq_loop:
   731 00000E69 41803C2427          <1>     cmp byte [r12], 0x27
   732 00000E6E 740C                <1>     je .sq_close
   733 00000E70 41803C2400          <1>     cmp byte [r12], 0
   734 00000E75 7436                <1>     je .pl_done
   735 00000E77 49FFC4              <1>     inc r12
   736 00000E7A EBED                <1>     jmp .sq_loop
   737                              <1> .sq_close:
   738 00000E7C 41C6042400          <1>     mov byte [r12], 0               ; null-terminate at closing '
   739 00000E81 49FFC4              <1>     inc r12
   740 00000E84 EB88                <1>     jmp .pl_skip_ws
   741                              <1> 
   742                              <1> .pl_unquoted:
   743 00000E86 41803C2420          <1>     cmp byte [r12], ' '
   744 00000E8B 7413                <1>     je .pl_end_token
   745 00000E8D 41803C2409          <1>     cmp byte [r12], 0x09            ; tab
   746 00000E92 740C                <1>     je .pl_end_token
   747 00000E94 41803C2400          <1>     cmp byte [r12], 0
   748 00000E99 7412                <1>     je .pl_done
   749 00000E9B 49FFC4              <1>     inc r12
   750 00000E9E EBE6                <1>     jmp .pl_unquoted
   751                              <1> 
   752                              <1> .pl_end_token:
   753 00000EA0 41C6042400          <1>     mov byte [r12], 0               ; null-terminate token
   754 00000EA5 49FFC4              <1>     inc r12
   755 00000EA8 E961FFFFFF          <1>     jmp .pl_skip_ws
   756                              <1> 
   757                              <1> .pl_done:
   758 00000EAD 4C89F8              <1>     mov rax, r15                    ; return argc
